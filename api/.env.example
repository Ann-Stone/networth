# App
APP_NAME=Networth API
DEBUG=true
PORT=9528

# Database location
# Format: sqlite:/// + absolute or ~-prefixed path. Use forward slashes
# on all platforms — backslashes get eaten by .env parsing.
# Parent directory is created automatically on first run.
#
#   macOS / Linux (default):
#     DATABASE_URL=sqlite:///~/.networth/networth.db
#
#   Windows, home folder:
#     DATABASE_URL=sqlite:///C:/Users/<you>/.networth/networth.db
#
#   Windows, secondary drive (e.g. D:):
#     DATABASE_URL=sqlite:///D:/Networth/data/networth.db
#
# Notes:
#   - Exactly THREE slashes after `sqlite:` (Windows drive letters are
#     already absolute; four slashes produces an invalid path).
#   - Avoid OneDrive / iCloud / Dropbox folders — they conflict with
#     SQLite's WAL locking.
#   - In-memory (tests only): sqlite:///:memory:
DATABASE_URL=sqlite:///~/.networth/networth.db

# Invoice import (optional)
INVOICE_CARD_NO=
INVOICE_PASSWORD=
INVOICE_APP_ID=
INVOICE_SKIP_PATH=config/invoice_skip.json

# Merchant mapping
MERCHANT_MAPPING_PATH=config/merchant_mapping.json

# One-off CSV import path
IMPORT_CSV=
