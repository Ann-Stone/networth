        "parameters": [
          {
            "in": "path",
            "name": "type",
            "required": true,
            "schema": {
              "enum": [
                "monthly",
                "yearly"
              ],
              "title": "Type",
              "type": "string"
            }
          },
          {
            "description": "Anchor month YYYYMM",
            "in": "query",
            "name": "vesting_month",
            "required": true,
            "schema": {
              "description": "Anchor month YYYYMM",
              "examples": [
                "202412"
