  "paths": {
    "/reports/income-statement/{type}": {
      "get": {
        "description": "Returns monthly (12 points) or yearly (10 points) profit-and-loss per period in three sections: 本業損益 (active income − living expenses), 投資損益 (dividends + realized capital gains + unrealized market-value change), and 綜合損益 (their sum), plus a window summary. Amounts are FX-converted to the base currency. Realized gains come from booked 資本利得 journals; unrealized covers stock holdings only.",
        "operationId": "get_income_statement_endpoint_reports_income_statement__type__get",
        "parameters": [
          {
            "in": "path",
            "name": "type",
            "required": true,
            "schema": {
              "enum": [
                "monthly",
                "yearly"
              ],
              "title": "Type",
              "type": "string"
            }
          },
          {
            "description": "Anchor month YYYYMM",
            "in": "query",
            "name": "vesting_month",
            "required": true,
            "schema": {
              "description": "Anchor month YYYYMM",
              "examples": [
                "202412"
              ],
              "pattern": "^\\d{6}$",
              "title": "Vesting Month",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_IncomeStatementReportRead_"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "example": {
                  "error": [
                    {
                      "input": {},
                      "loc": [
                        "body",
                        "field_name"
                      ],
                      "msg": "Field required",
                      "type": "missing"
                    }
                  ],
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Validation error — request payload failed Pydantic validation"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "error": "RuntimeError: unexpected failure",
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unhandled server error — wrapped by global exception handler"
          }
        },
        "summary": "Get comprehensive income statement (本業/投資/綜合損益)",
        "tags": [
          "reports"
        ]
      }
    }
  },
