    "/monthly-report/insurance-values/{vesting_month}": {
      "get": {
        "description": "For every insurance policy, return the latest recorded surrender value (解約金) on or before month-end (carried forward), with a ``recorded`` flag that is true only when entered in this exact month.",
        "operationId": "get_insurance_values_by_month_monthly_report_insurance_values__vesting_month__get",
        "parameters": [
          {
            "description": "YYYYMM",
            "in": "path",
            "name": "vesting_month",
            "required": true,
            "schema": {
              "description": "YYYYMM",
              "examples": [
                "202604"
              ],
              "pattern": "^\\d{6}$",
              "title": "Vesting Month",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_list_InsuranceValueMonthRead__"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "example": {
                  "error": [
                    {
                      "input": {},
                      "loc": [
                        "body",
                        "field_name"
                      ],
                      "msg": "Field required",
                      "type": "missing"
                    }
