                  "$ref": "#/components/schemas/ApiResponse_InsuranceValueRead_"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Insurance 42 not found",
                  "msg": "fail",
                  "status": 0
