          "pay_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Premium cadence",
            "examples": [
              "annual"
            ],
            "title": "Pay Type"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "YYYYMMDD",
            "examples": [
              "20200101"
            ],
            "title": "Start Date"
          }
        },
        "title": "InsuranceUpdate",
        "type": "object"
