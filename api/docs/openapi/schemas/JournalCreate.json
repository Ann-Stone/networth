{
  "components": {
    "schemas": {
      "JournalCreate": {
        "example": {
          "action_main": "EXP01",
          "action_main_table": "Code_Data",
          "action_main_type": "expense",
          "note": "Lunch",
          "spend_date": "20260418",
          "spend_way": "BANK-CHASE-01",
          "spend_way_table": "Account",
          "spend_way_type": "account",
          "spending": -123.45,
          "vesting_month": "202604"
        },
        "properties": {
          "action_main": {
            "description": "Reference to a Code_Data row's code_id. The set of valid code_ids is user-configurable via Settings → Codes.",
            "examples": [
              "EXP01"
            ],
            "title": "Action Main",
            "type": "string"
          },
          "action_main_table": {
            "description": "Source SQL table for action_main. Always 'Code_Data' for code-driven classification.",
            "examples": [
              "Code_Data"
            ],
            "title": "Action Main Table",
            "type": "string"
          },
          "action_main_type": {
            "description": "Mirror of the referenced Code_Data.code_type. Common values: 'Fixed', 'Floating', 'Income', 'Invest', 'Transfer'. Frontend should fetch /utilities/selections/codes for the live set.",
            "examples": [
              "expense"
            ],
            "title": "Action Main Type",
            "type": "string"
          },
          "action_sub": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional sub-classification: a Code_Data.code_id whose parent_id equals action_main. Null when there is no secondary breakdown.",
            "examples": [
              null
            ],
            "title": "Action Sub"
          },
          "action_sub_table": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Source SQL table for action_sub. 'Code_Data' when action_sub is set, null otherwise.",
            "examples": [
              null
            ],
            "title": "Action Sub Table"
          },
          "action_sub_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Mirror of the sub-code's Code_Data.code_type. Null when action_sub is null. Either all three action_sub_* fields are populated together or all three are null.",
            "examples": [
              null
            ],
            "title": "Action Sub Type"
          },
          "invoice_number": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Invoice number",
            "examples": [
              "AB12345678"
            ],
            "title": "Invoice Number"
          },
          "note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Free-form note",
            "examples": [
              "Lunch"
            ],
            "title": "Note"
          },
          "spend_date": {
            "description": "YYYYMMDD",
            "examples": [
              "20260418"
            ],
            "title": "Spend Date",
            "type": "string"
          },
          "spend_way": {
            "description": "Payment source id",
            "examples": [
              "BANK-CHASE-01"
            ],
            "title": "Spend Way",
            "type": "string"
          },
          "spend_way_table": {
            "description": "Source SQL table for spend_way. Must be 'Account' when spend_way_type='account', or 'Credit_Card' when spend_way_type='credit_card'.",
            "examples": [
              "Account"
            ],
            "title": "Spend Way Table",
            "type": "string"
          },
          "spend_way_type": {
            "description": "Polymorphic discriminator for spend_way. Valid values: 'account' (spend_way_table='Account', spend_way → Account.account_id) | 'credit_card' (spend_way_table='Credit_Card', spend_way → CreditCard.credit_card_id).",
            "examples": [
              "account"
            ],
            "title": "Spend Way Type",
            "type": "string"
          },
          "spending": {
            "description": "Positive = income, negative = expense",
            "examples": [
              -123.45
            ],
            "title": "Spending",
            "type": "number"
          },
          "vesting_month": {
            "description": "YYYYMM",
            "examples": [
              "202604"
            ],
            "title": "Vesting Month",
            "type": "string"
          }
        },
        "required": [
          "vesting_month",
          "spend_date",
          "spend_way",
          "spend_way_type",
          "spend_way_table",
          "action_main",
          "action_main_type",
          "action_main_table",
          "spending"
        ],
        "title": "JournalCreate",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Networth API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0"
}
