{
  "components": {
    "schemas": {
      "TargetSettingCreate": {
        "example": {
          "distinct_number": "T-2026-01",
          "setting_value": "Buy a house by end of year"
        },
        "properties": {
          "distinct_number": {
            "description": "Target row business ID",
            "examples": [
              "T-2026-01"
            ],
            "title": "Distinct Number",
            "type": "string"
          },
          "is_done": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Y/N; defaults to N when omitted",
            "examples": [
              "N"
            ],
            "title": "Is Done"
          },
          "setting_value": {
            "description": "Target description / value (free-form text)",
            "examples": [
              "Buy a house by end of year"
            ],
            "maxLength": 45,
            "title": "Setting Value",
            "type": "string"
          },
          "target_year": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "YYYY; defaults to the current year when omitted",
            "examples": [
              "2026"
            ],
            "title": "Target Year"
          }
        },
        "required": [
          "distinct_number",
          "setting_value"
        ],
        "title": "TargetSettingCreate",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Networth API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0"
}
