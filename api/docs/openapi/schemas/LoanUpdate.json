            "examples": [
              "Chase Checking"
            ],
            "title": "Account Name"
          },
          "amount": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Original loan amount",
            "examples": [
              250000.0
            ],
            "title": "Amount"
          },
          "apply_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
