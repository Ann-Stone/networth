            "examples": [
              0.27
            ],
            "title": "Rate",
            "type": "number"
          }
        },
        "required": [
          "owner",
          "amount",
          "rate"
        ],
        "title": "GiftItem",
        "type": "object"
      }
    }
  },
  "info": {
