              "202403"
            ],
            "title": "Period",
            "type": "string"
          }
        },
        "required": [
          "period",
          "operating",
          "investing",
          "financing",
          "net_change"
        ],
        "title": "CashFlowPoint",
        "type": "object"
      }
    }
  },
