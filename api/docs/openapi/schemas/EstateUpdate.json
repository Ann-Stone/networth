{
  "components": {
    "schemas": {
      "EstateUpdate": {
        "example": {
          "estate_status": "sold"
        },
        "properties": {
          "asset_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Asset category ID",
            "examples": [
              "AC-REAL-001"
            ],
            "title": "Asset Id"
          },
          "estate_address": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Physical address",
            "examples": [
              "123 Main St"
            ],
            "title": "Estate Address"
          },
          "estate_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Estate display name",
            "examples": [
              "Condo"
            ],
            "title": "Estate Name"
          },
          "estate_status": {
            "anyOf": [
              {
                "enum": [
                  "idle",
                  "live",
                  "rent",
                  "sold"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Status",
            "examples": [
              "sold"
            ],
            "title": "Estate Status"
          },
          "estate_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Estate type",
            "examples": [
              "residential"
            ],
            "title": "Estate Type"
          },
          "fx_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Currency code (TWD; USD/JPY/... for overseas property)",
            "examples": [
              "USD"
            ],
            "title": "Fx Code"
          },
          "loan_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Associated loan ID",
            "examples": [
              "LN-001"
            ],
            "title": "Loan Id"
          },
          "memo": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Free-form memo",
            "examples": [
              "Updated"
            ],
            "title": "Memo"
          },
          "obtain_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "YYYYMMDD",
            "examples": [
              "20200101"
            ],
            "title": "Obtain Date"
          },
          "region": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "House-price-index 縣市 (全國/臺北市/新北市/桃園市/臺中市/臺南市/高雄市); null → 全國",
            "examples": [
              "臺北市"
            ],
            "title": "Region"
          }
        },
        "title": "EstateUpdate",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Networth API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0"
}
