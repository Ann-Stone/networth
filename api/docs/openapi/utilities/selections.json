    "/utilities/selections/codes/{code_group}": {
      "get": {
        "description": "Return children of the parent code identified by code_group as a single 'sub' group.",
        "operationId": "list_sub_code_selections_utilities_selections_codes__code_group__get",
        "parameters": [
          {
            "description": "Parent code_id",
            "in": "path",
            "name": "code_group",
            "required": true,
            "schema": {
              "description": "Parent code_id",
              "examples": [
                "92"
              ],
              "title": "Code Group",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_list_SelectionGroup__"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Parent code 'XYZ' has no children",
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Parent code has no children"
          },
          "422": {
            "content": {
              "application/json": {
                "example": {
                  "error": [
                    {
                      "input": {},
                      "loc": [
                        "body",
                        "field_name"
                      ],
                      "msg": "Field required",
                      "type": "missing"
                    }
                  ],
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Validation error — request payload failed Pydantic validation"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "error": "RuntimeError: unexpected failure",
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unhandled server error — wrapped by global exception handler"
          }
        },
        "summary": "List sub-codes for a parent code",
        "tags": [
          "utilities",
          "utilities:selections"
        ]
      }
    },
