                        "body",
                        "field_name"
                      ],
                      "msg": "Field required",
                      "type": "missing"
                    }
                  ],
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Validation error — request payload failed Pydantic validation"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "error": "RuntimeError: unexpected failure",
                  "msg": "fail",
                  "status": 0
                },
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unhandled server error — wrapped by global exception handler"
          }
        },
        "summary": "Bulk update budgets",
        "tags": [
          "settings",
          "settings:budgets"
        ]
      }
