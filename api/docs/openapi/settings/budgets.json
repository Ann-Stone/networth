                  "$ref": "#/components/schemas/ApiResponse_list_BudgetRead__"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "error": "Budget rows 42 not found",
                  "msg": "fail",
                  "status": 0
                },
